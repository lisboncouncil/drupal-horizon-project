  return [
    'lc_event_registration_email_wrapper' => [
      'variables' => [
        'header_color' => '#0B4A89',
        'primary_color' => '#0B4A89',
        'logo_url' => '',
        'site_name' => '',
        'site_url' => '',
        'privacy_url' => '',
        'body_content' => '',
      ],
    ],
    'lc_event_registration_email_confirmation' => [
      'variables' => [
        'first_name' => '',
        'last_name' => '',
        'email' => '',
        'event_title' => '',
        'event_url' => '',
        'event_date' => '',
        'event_location' => '',
        'coordinates' => NULL,
        'map_image_url' => NULL,
        'agenda_html' => '',
        'organisation' => '',
        'online_link' => '',
        'ical_url' => '',
        'primary_color' => '#0B4A89',
        'secondary_color' => '#5a9e56',
      ],
    ],
    'lc_event_registration_email_notification' => [
      'variables' => [
        'event_title' => '',
        'first_name' => '',
        'last_name' => '',
        'reg_email' => '',
        'optional_fields' => [],
        'count' => 0,
        'capacity' => 0,
        'admin_url' => '',
      ],
    ],
  ];
}

/**
 * Implements hook_preprocess_html().
 *
 * Adds 'event-registration' body class on registration pages.
 */
function lc_event_registration_preprocess_html(array &$variables): void {
  $route = \Drupal::routeMatch()->getRouteName();
  if ($route && str_starts_with($route, 'lc_event_registration.')) {
    $variables['attributes']['class'][] = 'event-registration';
  }
}

/**
 * Implements hook_mail().
 */
function lc_event_registration_mail($key, &$message, $params) {
  $message['subject'] = $params['subject'] ?? 'Event Registration';
  $message['body'][] = $params['body'] ?? '';
  $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
}
