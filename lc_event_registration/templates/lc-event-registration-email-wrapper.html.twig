<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; background-color: #f0f2f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f0f2f5;">
  <tr>
    <td align="center" style="padding: 30px 10px;">
      <table width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; width: 100%; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
        {# Header band #}
        <tr>
          <td style="background-color: {{ header_color }}; padding: 24px 40px; text-align: center;">
            {% if logo_url %}
              <img src="{{ logo_url }}" alt="{{ site_name }}" height="60" style="display: block; margin: 0 auto; height: 60px; width: auto;">
            {% else %}
              <span style="font-size: 22px; font-weight: 700; color: #ffffff; letter-spacing: 0.5px;">{{ site_name }}</span>
            {% endif %}
          </td>
        </tr>

        {# Body content #}
        {{ body_content|raw }}

        {# Footer #}
        <tr>
          <td style="padding: 0 40px;">
            <table width="100%" cellpadding="0" cellspacing="0"><tr><td style="border-top: 3px solid {{ primary_color }};"></td></tr></table>
          </td>
        </tr>
        <tr>
          <td style="padding: 20px 40px 12px; background-color: #f8f9fa; text-align: center; font-size: 13px; color: #555;">
            <p style="margin: 0 0 6px; font-weight: 600;">
              <a href="{{ site_url }}" style="color: {{ primary_color }}; text-decoration: none;">{{ site_name }}</a>
            </p>
            <p style="margin: 0 0 10px; font-size: 12px; color: #888;">
              <a href="{{ site_url }}" style="color: #888; text-decoration: none;">{{ site_url|replace({'https://': '', 'http://': ''}) }}</a>
              &nbsp;&middot;&nbsp;
              <a href="{{ privacy_url }}" style="color: #888; text-decoration: none;">Privacy Policy</a>
            </p>
            <p style="margin: 0 0 10px; font-size: 11px; color: #aaa; line-height: 1.5;">
              Funded by the European Union under the Digital Europe Programme.
            </p>
            <p style="margin: 0; font-size: 11px; color: #bbb;">
              This is an automated message. Please do not reply directly to this email.
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
</body>
</html>
