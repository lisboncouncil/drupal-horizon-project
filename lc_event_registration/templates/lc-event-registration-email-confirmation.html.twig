{# Confirmation email body — rendered inside the email wrapper. #}

{# Success heading #}
<tr>
  <td style="padding: 30px 40px 10px;">
    <p style="font-size: 20px; color: {{ secondary_color }}; margin: 0 0 5px; font-weight: 600;">&#10003; Registration Confirmed</p>
  </td>
</tr>

{# Greeting #}
<tr>
  <td style="padding: 10px 40px 20px; font-size: 15px; line-height: 1.6; color: #1D1D1D;">
    <p style="margin: 0 0 15px;">Dear {{ first_name }},</p>
    <p style="margin: 0;">Your registration for <strong>{{ event_title }}</strong> has been confirmed.</p>
  </td>
</tr>

{# Event details card #}
<tr>
  <td style="padding: 0 40px 20px;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f8f9fa; border-radius: 8px;">
      <tr>
        <td style="padding: 20px 24px;">
          <p style="font-size: 18px; font-weight: 700; color: {{ primary_color }}; margin: 0 0 12px;">{{ event_title }}</p>
          {% if event_date %}
            <p style="font-size: 14px; color: #555; margin: 0 0 6px;">&#128197; {{ event_date }}</p>
          {% endif %}
          {% if event_location %}
            <p style="font-size: 14px; color: #555; margin: 0 0 6px;">&#128205; {{ event_location }}</p>
          {% endif %}
          {% if online_link %}
            <p style="font-size: 14px; color: #555; margin: 0 0 6px;">&#128187; <a href="{{ online_link }}" style="color: {{ primary_color }}; text-decoration: none;">Join online</a></p>
          {% endif %}
          <p style="margin: 16px 0 0;">
            <a href="{{ event_url }}" style="display: inline-block; padding: 10px 24px; background-color: {{ primary_color }}; color: #ffffff; text-decoration: none; border-radius: 4px; font-size: 14px; font-weight: 600;">View event details</a>
            {% if online_link %}
              <a href="{{ online_link }}" style="display: inline-block; padding: 10px 24px; background-color: {{ secondary_color }}; color: #ffffff; text-decoration: none; border-radius: 4px; font-size: 14px; font-weight: 600; margin-left: 8px;">Join online</a>
            {% endif %}
          </p>
        </td>
      </tr>
    </table>
  </td>
</tr>

{# Map image and links #}
{% if coordinates %}
<tr>
  <td style="padding: 0 40px 0;">
    <hr style="border: none; border-top: 1px solid #ddd; margin: 20px 0;">
    {% if map_image_url %}
    <a href="https://www.google.com/maps?q={{ coordinates.lat }},{{ coordinates.lng }}" style="display: block; text-decoration: none;">
      <img src="{{ map_image_url }}" alt="Event location map" width="520" style="display: block; width: 100%; max-width: 520px; height: auto; border-radius: 6px; margin-bottom: 12px;">
    </a>
    {% endif %}
    <p style="margin: 0; text-align: center;">
      <a href="https://www.google.com/maps?q={{ coordinates.lat }},{{ coordinates.lng }}" style="color: {{ primary_color }}; text-decoration: none; font-size: 14px; margin-right: 20px;">&#127758; Open in Google Maps</a>
      <a href="https://www.openstreetmap.org/?mlat={{ coordinates.lat }}&mlon={{ coordinates.lng }}&zoom=15" style="color: {{ primary_color }}; text-decoration: none; font-size: 14px;">&#127758; Open in OpenStreetMap</a>
    </p>
  </td>
</tr>
{% endif %}

{# Agenda #}
{% if agenda_html %}
<tr>
  <td style="padding: 0 40px 20px;">
    <hr style="border: none; border-top: 1px solid #ddd; margin: 20px 0;">
    <p style="font-size: 13px; color: #888; margin: 0 0 8px; text-transform: uppercase; letter-spacing: 0.5px;">Agenda</p>
    <div style="font-size: 14px; line-height: 1.6; color: #1D1D1D;">{{ agenda_html|raw }}</div>
  </td>
</tr>
{% endif %}

{# Registration summary #}
<tr>
  <td style="padding: 0 40px 20px;">
    <hr style="border: none; border-top: 1px solid #ddd; margin: 20px 0;">
    <p style="font-size: 13px; color: #888; margin: 0 0 8px; text-transform: uppercase; letter-spacing: 0.5px;">Your details</p>
    <table width="100%" cellpadding="0" cellspacing="0" style="font-size: 14px; color: #1D1D1D;">
      <tr>
        <td style="padding: 4px 0; color: #888; width: 120px;">Name</td>
        <td style="padding: 4px 0;">{{ first_name }} {{ last_name }}</td>
      </tr>
      <tr>
        <td style="padding: 4px 0; color: #888;">Email</td>
        <td style="padding: 4px 0;">{{ email }}</td>
      </tr>
      {% if organisation %}
      <tr>
        <td style="padding: 4px 0; color: #888;">Organisation</td>
        <td style="padding: 4px 0;">{{ organisation }}</td>
      </tr>
      {% endif %}
    </table>
  </td>
</tr>

{# iCal button #}
<tr>
  <td style="padding: 0 40px 30px; text-align: center;">
    <a href="{{ ical_url }}" style="display: inline-block; padding: 10px 24px; background-color: #ffffff; color: {{ primary_color }}; text-decoration: none; border-radius: 4px; font-size: 14px; font-weight: 600; border: 2px solid {{ primary_color }};">&#128197; Add to calendar</a>
  </td>
</tr>
